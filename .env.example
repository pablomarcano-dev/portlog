# === App ===
NODE_ENV=production
PORT=3000
APP_URL=http://YOUR_SERVER_IP

# === Orchestration (docker-compose only) ===
COMPOSE_PROJECT_NAME=portlog

# === Database (self-hosted Postgres in production docker-compose.yml) ===
POSTGRES_USER=portlog
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://portlog:change_me_in_production@postgres:5432/portlog

# === Cookie ===
# Set to false when serving over plain HTTP (no HTTPS/domain)
COOKIE_SECURE=true

# === JWT ===
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# === MinIO ===
MINIO_ROOT_USER=portlog
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sgc-documents

# === AIS Provider ===
AIS_PROVIDER=marinetraffic
AIS_API_KEY=

# === Email (SMTP) ===
# Development: point at Mailhog (docker-compose.dev.yml adds mailhog service on :1025)
# Production: use an external SMTP relay (SendGrid, AWS SES, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=portlog@localhost

# === WhatsApp ===
WHATSAPP_MODE=local
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# === Logging ===
LOG_LEVEL=info
