# === App ===
NODE_ENV=production
PORT=3000
APP_URL=https://portlog.example.com

# === Orchestration (docker-compose only) ===
COMPOSE_PROJECT_NAME=portlog

# === Database (Neon in production; local Postgres for dev via docker-compose.dev.yml) ===
# Pooler URL — used by the app at runtime
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.us-east-2.aws.neon.tech/portlog?sslmode=require
# Direct URL — used by prisma migrate deploy only
DIRECT_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/portlog?sslmode=require

# === JWT ===
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
# Generate with: openssl rand -base64 32  (must differ from JWT_SECRET)
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# === MinIO ===
MINIO_ROOT_USER=portlog
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sgc-documents

# === AIS Provider ===
AIS_PROVIDER=marinetraffic
AIS_API_KEY=

# === Email (SMTP) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@portlog.example.com

# === WhatsApp ===
WHATSAPP_MODE=local
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# === Logging ===
LOG_LEVEL=info
