<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<style>
  body { font-family: Arial, sans-serif; font-size: 12px; margin: 0; padding: 24px; }
  h1 { font-size: 16px; border-bottom: 2px solid #333; padding-bottom: 8px; }
  table { width: 100%; border-collapse: collapse; margin-top: 16px; }
  th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; }
  th { background: #f0f0f0; font-weight: bold; }
  .footer { margin-top: 32px; font-size: 10px; color: #666; border-top: 1px solid #ccc; padding-top: 8px; }
</style>
</head>
<body>
<h1>PRE-ARRIVAL NOTIFICATION</h1>
<table>
  <tr><th>Vessel</th><td>{{vesselName}}</td></tr>
  <tr><th>IMO</th><td>{{imo}}</td></tr>
  <tr><th>Flag</th><td>{{flagName}}</td></tr>
  <tr><th>Port</th><td>{{portName}}</td></tr>
  <tr><th>Voyage No.</th><td>{{correlative}}</td></tr>
  <tr><th>ETA</th><td>{{eta}}</td></tr>
  <tr><th>ETB</th><td>{{etb}}</td></tr>
  <tr><th>Cargo</th><td>{{cargoName}}</td></tr>
  <tr><th>Quantity (MT)</th><td>{{quantity}}</td></tr>
  <tr><th>Agent</th><td>{{agentName}}</td></tr>
</table>
{{#if requirements}}
<p><strong>Special Requirements:</strong> {{requirements}}</p>
{{/if}}
<div class="footer">Generated: {{generatedAt}}</div>
</body>
</html>
