<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<style>
  body { font-family: Arial, sans-serif; font-size: 12px; margin: 24px; }
  h2 { text-align: center; }
  .header { margin-bottom: 16px; }
  table { width: 100%; border-collapse: collapse; margin-top: 8px; }
  th, td { border: 1px solid #555; padding: 6px 8px; text-align: left; }
  th { background: #eee; }
  .footer { margin-top: 16px; font-size: 10px; color: #888; }
</style>
</head>
<body>
  <h2>SH-66A — Overtime</h2>
  <div class="header">
    <strong>Vessel:</strong> {{nomination.vesselName}} &nbsp;|&nbsp;
    <strong>IMO:</strong> {{nomination.imo}} &nbsp;|&nbsp;
    <strong>Voyage:</strong> {{nomination.voyageNumber}} &nbsp;|&nbsp;
    <strong>Port:</strong> {{nomination.opPortName}}<br>
    <strong>Correlativo:</strong> {{nomination.correlative}} &nbsp;|&nbsp;
    <strong>ETA:</strong> {{nomination.etaDate}}
  </div>
  {{#if doc.vesselReference}}<p><strong>Ref:</strong> {{doc.vesselReference}}</p>{{/if}}
  <table>
    <thead>
      <tr><th>Date</th><th>From</th><th>To</th><th>Activity</th></tr>
    </thead>
    <tbody>
      {{#each doc.rows}}
      <tr>
        <td>{{this.date}}</td>
        <td>{{this.from}}</td>
        <td>{{this.to}}</td>
        <td>{{this.activity}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{#if doc.notes}}<p><strong>Notes:</strong> {{doc.notes}}</p>{{/if}}
  <div class="footer">Generated: {{generatedAt}}</div>
</body>
</html>
