// ---------------------------------------------------------------------------
// M4 — PEDR & Port Documents
// ---------------------------------------------------------------------------
// PEDR (Pedido de Entrada y Despacho de Recalada) is the multi-stage compliance
// shell wrapping a Nomination once vessel activity begins. One PEDR per Nomination
// (1:1). Four stages: PREARRIBO → ATENCION → DESPACHO → CIERRE.
//
// Stage advancement is forward-only — enforced at service layer in M4-S2.
// pedr_stage_history is APPEND-ONLY: no UPDATE, no DELETE permitted.
// PedrEvent is APPEND-ONLY: events represent real-world timestamps; mutating
// them rewrites legal history. No updatedAt on PedrEvent or PedrStageHistory.
//
// Document.minioKey is unique and immutable once written (service-layer ban on
// update is enforced in M4-S2). File bytes never live in Postgres (Rule 7).
//
// All timestamp fields use @db.Timestamptz(6) per Golden Rule 6.
// ---------------------------------------------------------------------------

enum PedrStage {
  PRE_ARRIVAL
  ATTENDING
  DISPATCH
  CLOSING
}

enum PedrSubDocumentType {
  ACKNOWLEDGEMENT
  PREARRIVAL
  ETA_ETB
  NOR
  SOF
  CARGO_UPDATE
}

// FINALIZED is legally significant for SOF: once finalized, the service layer
// must reject any further updates. The DB enforces consistency via a CHECK
// constraint added in raw migration SQL (see migration m4_pedr_foundation).
enum PedrSubDocumentStatus {
  DRAFT
  SENT
  FINALIZED
  CANCELLED
}

// PedrEventKind captures the discrete real-world events that compose port
// timelines (SOF). The OTHER value allows free-form events without a migration.
// Append-only: no updates after insert.
enum PedrEventKind {
  ARRIVED
  ANCHORED
  NOR_TENDERED
  LOADING_START
  LOADING_END
  DISCHARGE_START
  DISCHARGE_END
  DEPARTED
  OTHER
}

// ---------------------------------------------------------------------------
// Pedr — one row per nomination, stage-aware compliance shell
// ---------------------------------------------------------------------------
model Pedr {
  id           String     @id @default(uuid()) @db.Uuid
  nominationId String     @unique @db.Uuid
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Restrict)

  currentStage PedrStage @default(PRE_ARRIVAL)

  // ADM-editable free-text checklist / requirements per stage
  requirements String? @db.Text

  // Operational metadata — mutable JSON bag for alert flags and computed state.
  // Used by the ETA stale-alert cron to record { etaStaleAlert, etaLastSent }.
  metadata Json?

  createdById String
  createdBy   User     @relation("PedrCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  stageHistory    PedrStageHistory[]
  subDocuments    PedrSubDocument[]
  events          PedrEvent[]
  documents       Document[]
  emailDispatches EmailDispatch[]    @relation("PedrEmailDispatches")
  etaRecord       PedrEtaRecord?

  @@index([nominationId])
  @@index([currentStage])
  @@map("pedrs")
}

// ---------------------------------------------------------------------------
// PedrStageHistory — append-only stage transition ledger
// ---------------------------------------------------------------------------
// No updatedAt — this table is append-only (service layer enforces no
// deletes/updates). DB CHECK constraint ensures no self-loop transitions
// (added in raw migration SQL).
model PedrStageHistory {
  id          String     @id @default(uuid()) @db.Uuid
  pedrId      String     @db.Uuid
  pedr        Pedr       @relation(fields: [pedrId], references: [id], onDelete: Cascade)
  fromStage   PedrStage? // null on initial insert
  toStage     PedrStage
  changedById String
  changedBy   User       @relation("PedrStageChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  reason      String?
  // No updatedAt — append-only
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)

  @@index([pedrId, createdAt])
  @@map("pedr_stage_history")
}

// ---------------------------------------------------------------------------
// PedrSubDocument — one row per sub-document instance per PEDR
// ---------------------------------------------------------------------------
// payload: Zod-validated per-type form data (discriminated by type in M4-S1).
// recipients: array of { contactId?, email, name? } JSON objects.
// finalizedAt + finalizedById must be set together — DB CHECK enforces this
// (see raw migration SQL). Once FINALIZED, service layer must reject updates.
// Partial unique index enforces singleton sub-docs for ACKNOWLEDGEMENT,
// PREARRIVAL, ETA_ETB, NOR (SOF and CARGO_UPDATE may have multiple instances).
model PedrSubDocument {
  id     String @id @default(uuid()) @db.Uuid
  pedrId String @db.Uuid
  pedr   Pedr   @relation(fields: [pedrId], references: [id], onDelete: Cascade)

  type   PedrSubDocumentType
  status PedrSubDocumentStatus @default(DRAFT)
  stage  PedrStage

  // Per-type form fields, Zod-validated in M4-S1
  payload    Json    @default("{}")
  // Array of { contactId?, email, name? }
  recipients Json    @default("[]")
  // Free-text body for simple form sub-docs
  body       String? @db.Text

  // Finalization — legally significant for SOF
  finalizedAt   DateTime? @db.Timestamptz(6)
  finalizedById String?
  finalizedBy   User?     @relation("PedrSubDocumentFinalizedBy", fields: [finalizedById], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User     @relation("PedrSubDocumentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  events    PedrEvent[]
  documents Document[]

  @@index([pedrId, type])
  @@map("pedr_sub_documents")
}

// ---------------------------------------------------------------------------
// PedrEvent — append-only event ledger feeding SOF timelines
// ---------------------------------------------------------------------------
// occurredAt is the legally recorded timestamp (user-entered, represents the
// real-world time the event happened). recordedAt is the DB insert time.
// No updatedAt — append-only. Mutating events rewrites legal history.
model PedrEvent {
  id     String @id @default(uuid()) @db.Uuid
  pedrId String @db.Uuid
  pedr   Pedr   @relation(fields: [pedrId], references: [id], onDelete: Cascade)

  // Nullable: events can belong to a SOF sub-doc or float at PEDR level
  subDocumentId String?          @db.Uuid
  subDocument   PedrSubDocument? @relation(fields: [subDocumentId], references: [id], onDelete: SetNull)

  kind       PedrEventKind
  // The legally recorded timestamp — when the event actually happened
  occurredAt DateTime      @db.Timestamptz(6)
  note       String?       @db.Text

  recordedById String
  recordedBy   User     @relation("PedrEventRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  // recordedAt is the DB insert time — not the event time
  recordedAt   DateTime @default(now()) @db.Timestamptz(6)
  // No updatedAt — append-only

  @@index([pedrId, occurredAt])
  @@map("pedr_events")
}

// ---------------------------------------------------------------------------
// PedrEtaRecord — persisted ETA data for the "Answer ETA" modal (one per PEDR)
// ---------------------------------------------------------------------------
// Upserted whenever the user saves the Answer ETA form. The three checkbox
// fields (etaNotifyOn, etpobOn, etbOn) control which datetimes appear in
// outgoing ETA emails (ETA_REQUEST, ETA_TERMINAL, ETA_REPLY).
model PedrEtaRecord {
  id          String    @id @default(cuid())
  pedrId      String    @unique @db.Uuid
  pedr        Pedr      @relation(fields: [pedrId], references: [id], onDelete: Cascade)
  msgEta      DateTime? @db.Timestamptz(6)
  etaNotify   DateTime? @db.Timestamptz(6)
  etaNotifyOn Boolean   @default(false)
  etpob       DateTime? @db.Timestamptz(6)
  etpobOn     Boolean   @default(false)
  etb         DateTime? @db.Timestamptz(6)
  etbOn       Boolean   @default(false)
  refMessage  String?   @db.Text
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@map("pedr_eta_records")
}

// ---------------------------------------------------------------------------
// Document — tracks every generated PDF (MinIO key, type, stage)
// ---------------------------------------------------------------------------
// minioKey is unique and immutable once written — @unique enforces immutability
// at DB level. File bytes never live in Postgres (Golden Rule 7).
// docType is kept wide (e.g. "acknowledgement", "nor", "sof", "sh-66a") so
// M5 (SH-xx) can reuse this table without a migration.
// nominationId is kept as a direct FK for fast cross-cutting queries
// (e.g. "all documents for nomination X" without joining through Pedr).
model Document {
  id String @id @default(uuid()) @db.Uuid

  // Direct FK to Nomination for cross-cutting queries (M5 reuse)
  nominationId String     @db.Uuid
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Restrict)

  // Nullable: some documents are PEDR-level, not sub-document-level
  pedrId String? @db.Uuid
  pedr   Pedr?   @relation(fields: [pedrId], references: [id], onDelete: Cascade)

  subDocumentId String?          @db.Uuid
  subDocument   PedrSubDocument? @relation(fields: [subDocumentId], references: [id], onDelete: SetNull)

  stage     PedrStage
  // Wide type string — M5 SH-xx rows can reuse this table
  docType   String
  // Full object path in MinIO — unique and immutable
  minioKey  String    @unique
  mimeType  String    @default("application/pdf")
  sizeBytes Int?

  createdById String
  createdBy   User     @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([nominationId, createdAt])
  @@index([pedrId, stage])
  @@map("documents")
}
