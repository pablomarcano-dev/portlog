model FleetVessel {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portUnlocode String
  imo          String
  name         String?
  addedAt      DateTime  @default(now()) @db.Timestamptz
  zarpeSince   DateTime? @db.Timestamptz

  @@unique([userId, portUnlocode, imo])
  @@index([userId, portUnlocode])
  @@map("fleet_vessels")
}
