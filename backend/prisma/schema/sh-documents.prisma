// ---------------------------------------------------------------------------
// M5 — SH-xx Documents
// ---------------------------------------------------------------------------

enum SHDocumentType {
  SH_66A
  SH_09A
  SH_28A
  SH_29A
  COMMENT
  OTHER
}

enum SHDocumentStatus {
  DRAFT
  FINALIZED
  SENT
}

model SHDocument {
  id           String     @id @default(uuid()) @db.Uuid
  nominationId String     @db.Uuid
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)

  type   SHDocumentType
  status SHDocumentStatus @default(DRAFT)

  // Type-specific form contents — discriminated union validated in @portlog/schemas
  data Json @default("{}")

  // Populated once the Generate action produces a PDF
  minioKey       String?   @unique
  pdfGeneratedAt DateTime? @db.Timestamptz(6)

  // Populated after email dispatch
  sentAt DateTime? @db.Timestamptz(6)

  // Human-readable label shown in lists (e.g. "Overtime 2026-05-21")
  title String?

  createdById String
  createdBy   User     @relation("SHDocCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  dispatches ShDocumentDispatch[]

  @@index([nominationId, type])
  @@index([nominationId, status])
  @@map("sh_documents")
}

// ---------------------------------------------------------------------------
// M5-S2 — SH-xx Email Dispatch log
// ---------------------------------------------------------------------------
// Append-only audit trail for every email send attempt on a SH-xx document.
// sentAt and error are updated after the async send result is known.
// All timestamps use @db.Timestamptz(6) per Golden Rule 6.
// ---------------------------------------------------------------------------

model ShDocumentDispatch {
  id            String     @id @default(cuid())
  shDocumentId  String     @db.Uuid
  shDocument    SHDocument @relation(fields: [shDocumentId], references: [id], onDelete: Cascade)
  toAddresses   String[]
  ccAddresses   String[]   @default([])
  bccAddresses  String[]   @default([])
  subject       String
  bodyHtml      String?    @db.Text
  pdfStorageKey String
  sentAt        DateTime?  @db.Timestamptz(6)
  sentById      String
  sentBy        User       @relation("ShDocDispatchSentBy", fields: [sentById], references: [id], onDelete: Restrict)
  error         String?
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  attachments   EmailAttachment[]

  @@index([shDocumentId, createdAt])
  @@map("sh_document_dispatches")
}
