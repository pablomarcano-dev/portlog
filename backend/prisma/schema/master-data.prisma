// ---------------------------------------------------------------------------
// M2 — Master Data
// ---------------------------------------------------------------------------
// All master-data entities follow the same conventions:
//   - cuid() primary keys (consistent with User, AuditLog)
//   - snake_case plural table names via @@map
//   - comments String? @db.Text — new requirement across all legacy forms
//   - createdAt / updatedAt with @db.Timestamptz for UTC storage
//   - name indexes on lookup-heavy tables
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Flag — country flag codes (ISO 3166-1)
// ---------------------------------------------------------------------------
model Flag {
  id           String   @id @default(cuid())
  name         String   @unique
  abbreviation String?
  comments     String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  shipParticulars ShipParticular[]

  @@index([name])
  @@map("flags")
}

// ---------------------------------------------------------------------------
// Activity — operational activity types
// ---------------------------------------------------------------------------
model Activity {
  id        String   @id @default(cuid())
  name      String   @unique
  comments  String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // SOF back-relation
  sofEntries SofEntry[] @relation("SofEntryActivity")

  @@map("activities")
}

// ---------------------------------------------------------------------------
// Cargo — cargo type catalog (a.k.a. "products" on nomination parcels)
// category gates which nominations a product may appear on: OT nominations only
// accept OT-category products; SN products (the default) are unrestricted.
// ---------------------------------------------------------------------------
enum CargoCategory {
  SN
  OT
}

model Cargo {
  id        String        @id @default(cuid())
  name      String
  bblUnit   String // e.g. "BBL", "MT"
  category  CargoCategory @default(SN)
  comments  String?       @db.Text
  createdAt DateTime      @default(now()) @db.Timestamptz
  updatedAt DateTime      @updatedAt @db.Timestamptz

  @@map("cargoes")
}

// ---------------------------------------------------------------------------
// Port — flat port directory; piers are a child table (Pier)
// ---------------------------------------------------------------------------
model Port {
  id           String   @id @default(cuid())
  name         String
  abbreviation String?
  country      String?
  emailGroup   String?
  comments     String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  piers Pier[]

  // Named back-relations for the port FK fields on Nomination
  nominationsAsOpPort   Nomination[] @relation("NominationOpPort")
  nominationsAsLastPort Nomination[] @relation("NominationLastPort")
  nominationsAsNextPort Nomination[] @relation("NominationNextPort")
  nominationsAsDisPort  Nomination[] @relation("NominationDisPort")

  // SOF back-relations
  sofTimesheetsAsLastPort SofTimesheet[] @relation("SofTimesheetLastPort")
  sofTimesheetsAsNextPort SofTimesheet[] @relation("SofTimesheetNextPort")

  @@index([name])
  @@map("ports")
}

// ---------------------------------------------------------------------------
// Pier — simple name list under a port; nominations reference a specific pier
// ---------------------------------------------------------------------------
model Pier {
  id        String   @id @default(cuid())
  name      String
  portId    String
  port      Port     @relation(fields: [portId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  nominations   Nomination[]
  sofTimesheets SofTimesheet[] @relation("SofTimesheetPier")

  @@index([portId])
  @@map("piers")
}

// ---------------------------------------------------------------------------
// Crew — ship crew member directory
// ---------------------------------------------------------------------------
model Crew {
  id             String   @id @default(cuid())
  name           String
  position       String?
  documentNumber String?
  nationality    String?
  comments       String?  @db.Text
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  @@index([name])
  @@map("crew")
}

// ---------------------------------------------------------------------------
// Charterer — vessel charterers
// ---------------------------------------------------------------------------
model Charterer {
  id          String   @id @default(cuid())
  name        String
  address     String?
  contactInfo String?  @db.Text
  comments    String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  contacts Contact[]

  @@index([name])
  @@map("charterers")
}

// ---------------------------------------------------------------------------
// Shipper — cargo shippers
// ---------------------------------------------------------------------------
model Shipper {
  id            String   @id @default(cuid())
  name          String
  email         String?
  businessPhone String?
  businessFax   String?
  address       String?
  comments      String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  contacts Contact[]

  @@index([name])
  @@map("shippers")
}

// ---------------------------------------------------------------------------
// Agent — port agents
// ---------------------------------------------------------------------------
model Agent {
  id          String   @id @default(cuid())
  name        String
  address     String?
  contactInfo String?  @db.Text
  comments    String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([name])
  @@map("agents")
}

// ---------------------------------------------------------------------------
// Operator — vessel operators
// location validated to "L" (local) | "E" (exterior) at the application layer
// sendCopy: whether to CC this operator on outbound documents
// itemsProforma: placeholder JSON for proforma line items (full normalization deferred)
// ---------------------------------------------------------------------------
model Operator {
  id                   String   @id @default(cuid())
  name                 String
  email                String?
  businessPhone        String?
  businessFax          String?
  address              String?
  standardRequirements String?  @db.Text
  sendCopy             Boolean  @default(false)
  // "L" = local | "E" = exterior — enforced at app layer, not DB constraint
  location             String?
  // Placeholder for proforma line items; full normalization deferred to a later milestone
  itemsProforma        Json?
  comments             String?  @db.Text
  createdAt            DateTime @default(now()) @db.Timestamptz
  updatedAt            DateTime @updatedAt @db.Timestamptz

  contacts        Contact[]
  shipParticulars ShipParticular[]

  @@index([name])
  @@map("operators")
}

// ---------------------------------------------------------------------------
// Owner — vessel owners
// Contains CRM and financial fields.
// Access to agreements + historyJson is gated by the "owner.financial" permission
// (enforced in the service layer — guard implementation is in M2-S12).
// notes: free-text separate from the standard comments field (per legacy form).
// historyJson: JSON blob for Buques/OTs/Factura/PagosRecibidos — full normalization deferred.
// ---------------------------------------------------------------------------
model Owner {
  id              String   @id @default(cuid())
  contactList     String?
  quantity        Int?
  contactNumber   String?
  name            String
  physicalAddress String?
  phones          String?
  address         String?
  position        String?
  socialMedia     String?
  // Free-text CRM field separate from the standard `comments` column (per legacy form spec)
  notes           String?  @db.Text
  birthday        String?
  preferences     String?  @db.Text
  recommendations String?  @db.Text
  business        String?  @db.Text
  webpage         String?
  // Financial fields — access gated by "owner.financial" permission (M2-S12)
  agreements      String?  @db.Text
  // JSON blob for Buques / OTs / Factura / PagosRecibidos history.
  // Full relational normalization deferred to a future milestone.
  historyJson     Json?
  comments        String?  @db.Text
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  contacts        Contact[]
  shipParticulars ShipParticular[]

  @@index([name])
  @@map("owners")
}

// ---------------------------------------------------------------------------
// Supplier — service providers (Proveedores)
// ---------------------------------------------------------------------------
model Supplier {
  id              String   @id @default(cuid())
  name            String
  contacts        String?  @db.Text
  address         String?
  services        String?  @db.Text
  kyc             String?  @db.Text
  phones          String?
  emails          String?  @db.Text
  certificates    String?  @db.Text
  rates           String?  @db.Text
  serviceContract String?  @db.Text
  agreements      String?  @db.Text
  comments        String?  @db.Text
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@index([name])
  @@map("suppliers")
}

// ---------------------------------------------------------------------------
// Client — port agency clients (Clientes)
// ---------------------------------------------------------------------------
model Client {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  phone2          String?
  physicalAddress String?
  billingAddress  String?
  postalAddress   String?
  taxAddress      String?
  otherAddress    String?
  fax             String?
  mobile          String?
  email           String?
  emailGroup      String?
  tariff          String?  @db.Text
  instructions    String?  @db.Text
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  sales Sale[]

  @@index([name])
  @@map("clients")
}

// ---------------------------------------------------------------------------
// Service — sale service catalog (Servicios)
// No default price: price is always typed per sale. Distinct from the future
// M6 "service requests" operational module (SCOPE.md 08).
// ---------------------------------------------------------------------------
model Service {
  id        String   @id @default(cuid())
  name      String
  comments  String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  sales Sale[]

  @@index([name])
  @@map("services")
}

// ---------------------------------------------------------------------------
// Contact — generic contacts directory
// Cross-linked to Shipper / Operator / Owner / Charterer via four nullable FKs.
// Business rule: at most ONE of the four entity FKs may be non-null per row.
// This is enforced by the CHECK constraint `contacts_single_owner_chk` added
// directly to the migration SQL (Prisma cannot express CHECK constraints natively).
// ---------------------------------------------------------------------------
model Contact {
  id            String     @id @default(cuid())
  name          String
  email         String?
  homePhone     String?
  mobile        String?
  businessPhone String?
  businessFax   String?
  address       String?
  // Entity FK cross-links — at most one may be non-null (enforced by DB CHECK constraint)
  shipperId     String?
  shipper       Shipper?   @relation(fields: [shipperId], references: [id], onDelete: SetNull)
  operatorId    String?
  operator      Operator?  @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  ownerId       String?
  owner         Owner?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  charterId     String?
  charterer     Charterer? @relation(fields: [charterId], references: [id], onDelete: SetNull)
  comments      String?    @db.Text
  createdAt     DateTime   @default(now()) @db.Timestamptz
  updatedAt     DateTime   @updatedAt @db.Timestamptz

  @@map("contacts")
}

// ---------------------------------------------------------------------------
// Branch — company branches (Sucursal)
// Resolves Open Question #5 from SCOPE.md: screenshot confirms Branch is a
// dropdown FK on every nomination, not a label derived from Port.
// ---------------------------------------------------------------------------
model Branch {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique // short identifier e.g. "LGR", "PLC"
  comments      String?  @db.Text
  // Operational contact details — used in email signatures
  email         String? // branch operational email e.g. lgr@navieramar.com
  address       String?  @db.Text
  phone         String?
  fax           String?
  mobile24h     String? // 24h mobile(s), free text (may contain multiple numbers)
  coverage      String?  @db.Text // ports/terminals attended by this branch
  // Branch contact person
  contactName   String? // e.g. "Ms. Cindy Moreno"
  contactTitle  String? // e.g. "Branch Manager"
  contactMobile String?
  contactEmail  String?
  // Central emails to always CC
  centralEmails String[] @default([])
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  nominations       Nomination[]
  documentTemplates BranchDocumentTemplate[]

  @@index([code])
  @@map("branches")
}

// ---------------------------------------------------------------------------
// ShipParticular — vessel registry
// imoNumber: unique when present; nullable (open question with client — allow null
//   for vessels not yet assigned an IMO or with non-standard entries, but uniqueness
//   is enforced among non-null values at DB level via @unique — Postgres silently
//   allows multiple NULLs in a unique index, which gives us partial-uniqueness semantics).
// callSign: marked @unique per business rule; open question whether duplicate
//   call signs across flags should be allowed — keeping @unique until client confirms otherwise.
// ---------------------------------------------------------------------------
model ShipParticular {
  id           String    @id @default(cuid())
  // Call sign is unique per vessel identification rules (open question: cross-flag duplicates allowed?)
  callSign     String    @unique
  name         String
  abbreviation String?
  loa          Decimal?  @db.Decimal(10, 3) // Length Overall in metres
  dwt          Decimal?  @db.Decimal(12, 3) // Deadweight Tonnage
  grt          Decimal?  @db.Decimal(12, 3) // Gross Register Tonnage
  nrt          Decimal?  @db.Decimal(12, 3) // Net Register Tonnage
  email        String?
  // imoNumber is unique among non-null values (Postgres unique index allows multiple NULLs).
  // Partial-uniqueness concern: Prisma @unique maps to a standard unique index, which is correct here.
  imoNumber    String?   @unique
  phone        String?
  phone2       String?
  fax          String?
  flagId       String
  flag         Flag      @relation(fields: [flagId], references: [id])
  ownerId      String?
  owner        Owner?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  operatorId   String?
  operator     Operator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  comments     String?   @db.Text
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  nominations Nomination[]

  @@index([name])
  @@index([imoNumber])
  @@map("ship_particulars")
}
