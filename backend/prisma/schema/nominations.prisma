// ---------------------------------------------------------------------------
// M3 — Nominations
// ---------------------------------------------------------------------------
// Central transactional entity. PEDR, port documents (M4), SH-xx docs (M5),
// and service requests (M6) all hang off of this table.
// All timestamp fields are @db.Timestamptz(6) — UTC-only, Golden Rule applies.
// NominationStatusHistory is append-only (enforced at service layer in M3-S2).
// ---------------------------------------------------------------------------

enum NominationStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NominationType {
  FULL_AGENCY
  OWNERS_AGENTS_ONLY
  CHARTERERS_AGENTS_ONLY
}

model Nomination {
  id          String @id @default(uuid()) @db.Uuid
  // Correlative drives the SN/OT number. Format rendered by service layer as `${YY}/${n.padStart(4,'0')}`.
  correlative Int    @unique @default(autoincrement())

  // Voyage
  voyageNumber String  // e.g. "01/PLC" — free text, Zod-validated in M3-S1
  voyageCode   String? // small dropdown next to Voy field (slide 4)

  // Vessel — required FK; cuid() PK on ShipParticular so plain String (no @db.Uuid)
  shipParticularId String
  shipParticular   ShipParticular @relation(fields: [shipParticularId], references: [id], onDelete: Restrict)

  // Branch (Sucursal) — resolves Open Question #5; screenshot confirms dropdown FK
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Restrict)

  // Supplementary fields from legacy General Info tab
  nomReply       DateTime? @db.Timestamptz(6)   // "Nom. Reply" — date nomination was acknowledged
  externalPortId String?
  externalPort   Port? @relation("NominationExternalPort", fields: [externalPortId], references: [id], onDelete: Restrict)
  mobileOnBoard  String?   // mobile number for person on board
  referenceNo    String?   // "Reference N°" free-text

  contactBlackBerry String?
  blindCopy         String?

  // Email recipients — populated at nomination creation and used by all email sends in this nomination flow
  emailTo  String[]
  emailCc  String[]
  emailBcc String[]

  // Ports — five named relations to the Port table; cuid() PKs so plain String FKs
  opPortId    String?
  pierId      String?
  lastPortId  String?
  nextPortId  String?
  disPortId   String?
  opPort      Port? @relation("NominationOpPort", fields: [opPortId], references: [id], onDelete: Restrict)
  pier        Pier? @relation(fields: [pierId], references: [id], onDelete: Restrict)
  lastPort    Port? @relation("NominationLastPort", fields: [lastPortId], references: [id], onDelete: Restrict)
  nextPort    Port? @relation("NominationNextPort", fields: [nextPortId], references: [id], onDelete: Restrict)
  disPort     Port? @relation("NominationDisPort", fields: [disPortId], references: [id], onDelete: Restrict)

  // Dates — always UTC; Golden Rule applies
  dateNominated DateTime  @db.Timestamptz(6)
  layDaysFirst  DateTime? @db.Timestamptz(6)
  layDaysLast   DateTime? @db.Timestamptz(6)
  etaDate       DateTime? @db.Timestamptz(6)

  // People (free-text except nominatedById which is a cuid FK to users)
  nominatedById String? // "Nomination Received by"; cuid FK — plain String
  nominatedBy   User?   @relation("NominationNominatedBy", fields: [nominatedById], references: [id], onDelete: Restrict)
  master        String?
  mic           String? // M.I.C.
  broker        String?
  boardingClerk String?
  inspector     String?

  // Type + subject
  nominationType NominationType @default(FULL_AGENCY)
  subject        String?

  // Parcels (Product/Qtty/Unit/Oper rows + cargo-update figures) as JSON; Zod-validated at service layer
  parcels Json @default("[]")

  // State machine
  status NominationStatus @default(DRAFT)

  // Audit — createdById is a required cuid FK to users
  createdById String
  createdBy   User   @relation("NominationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  statusHistory NominationStatusHistory[]

  // PEDR back-relations (M4)
  pedr      Pedr?
  documents Document[]

  // SH-xx back-relations (M5)
  shDocuments SHDocument[]

  // Branch Document Hub back-relations (M6)
  branchDocuments BranchDocumentInstance[]

  // Client list back-relation (M6)
  nominationClients NominationClient[]

  // SOF Timesheet back-relation
  sofTimesheet SofTimesheet?

  @@index([status])
  @@index([shipParticularId])
  @@index([dateNominated])
  @@map("nominations")
}

model NominationStatusHistory {
  id           String            @id @default(uuid()) @db.Uuid
  nominationId String            @db.Uuid
  nomination   Nomination        @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  fromStatus   NominationStatus? // null on initial DRAFT insert
  toStatus     NominationStatus
  // changedById is a cuid FK to users — plain String
  changedById String
  changedBy   User   @relation("NominationStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)
  // reason is required when toStatus = CANCELLED — enforced by DB CHECK constraint in migration SQL
  reason    String?
  // No updatedAt — this table is append-only (service layer enforces no deletes/updates in M3-S2)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([nominationId, createdAt])
  @@map("nomination_status_history")
}

// ---------------------------------------------------------------------------
// NominationClient — CLIENT LIST rows on a nomination
// Represents the Type / Name / Voy / Ref No / Broker table from the legacy UI.
// One nomination can have many client entries (Time Charter, Receivers, etc.)
// ---------------------------------------------------------------------------
model NominationClient {
  id           String     @id @default(uuid()) @db.Uuid
  nominationId String     @db.Uuid
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  type         String     // "Time Charter", "Receivers", etc. — free-text; no enum, client varies
  name         String
  voyageRef    String?
  referenceNo  String?
  proforma     String?
  broker       String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)

  @@index([nominationId])
  @@map("nomination_clients")
}

// ---------------------------------------------------------------------------
// SofTimesheet — 1-to-1 with Nomination
// Header fields for the Statement of Facts timesheet.
// All timestamps are Timestamptz(6) — UTC-only, Golden Rule applies.
// ---------------------------------------------------------------------------
model SofTimesheet {
  id            String     @id @default(cuid())
  nominationId  String     @unique @db.Uuid
  nomination    Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  lastPortId    String?
  lastPort      Port?      @relation("SofTimesheetLastPort", fields: [lastPortId], references: [id], onDelete: Restrict)
  nextPortId    String?
  nextPort      Port?      @relation("SofTimesheetNextPort", fields: [nextPortId], references: [id], onDelete: Restrict)
  pierId        String?
  pier          Pier?      @relation("SofTimesheetPier", fields: [pierId], references: [id], onDelete: Restrict)
  captain       String?
  mobileOnBoard String?
  // Sub-modal JSON blobs — one per support dialog
  bunkersData         Json?
  draftData           Json?
  sofParcelsData      Json?
  blFiguresData       Json?
  shipFiguresData     Json?
  lettersData         Json?
  remarksData         Json?
  slopDischargedData  Json?
  bunkersReceivedData Json?
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)

  entries SofEntry[]

  @@map("sof_timesheets")
}

// ---------------------------------------------------------------------------
// SofEntry — individual activity row within a SofTimesheet
// occurredAt is full UTC datetime; frontend splits into Date + Time inputs for display.
// order is 0-based display ordering, not auto-incremented — caller manages sequence.
// ---------------------------------------------------------------------------
model SofEntry {
  id             String       @id @default(cuid())
  sofTimesheetId String
  sofTimesheet   SofTimesheet @relation(fields: [sofTimesheetId], references: [id], onDelete: Cascade)
  occurredAt     DateTime     @db.Timestamptz(6)
  activityId     String?
  activity       Activity?    @relation("SofEntryActivity", fields: [activityId], references: [id], onDelete: SetNull)
  comment        String?
  order          Int
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  @@index([sofTimesheetId, order])
  @@map("sof_entries")
}
