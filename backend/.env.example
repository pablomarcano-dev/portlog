NODE_ENV=development
PORT=3000
APP_URL=https://portlog.example.com

# === Database (Neon) ===
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.us-east-2.aws.neon.tech/portlog?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/portlog?sslmode=require

# === JWT (Auth module — M1-S5) ===
# Access token secret — min 32 bytes. Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-min-32-bytes
JWT_ACCESS_TTL=15m
# Refresh token lifetime in days (stored as httpOnly cookie, rotated on each use)
JWT_REFRESH_TTL_DAYS=30

# === CORS & Cookies ===
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# === MinIO ===
MINIO_ROOT_USER=portlog
MINIO_ROOT_PASSWORD=          # Strong password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sgc-documents

# === AIS Provider (VesselFinder Basic plan ~USD 49/mo, 5,000 calls/month) ===
# API key from vf-api.com developer portal — NEVER commit the real key.
VESSELFINDER_API_KEY=
VESSELFINDER_BASE_URL=https://api.vf-api.com/v2
# Cache TTL in milliseconds (default: 300000 = 5 minutes; ToS allows up to 30 days)
AIS_CACHE_TTL_MS=300000
# Bottleneck token-bucket rate limit (VesselFinder allows 10 req/sec; we use 8 for headroom)
AIS_RATE_LIMIT_RPS=8

# === Datalastic API (Port & Vessel Finder) ===
# API key from datalastic.com — NEVER commit the real key.
DATALASTIC_API_KEY=
# Cache TTL in milliseconds (default: 300000 = 5 minutes)
DATALASTIC_CACHE_TTL_MS=300000

# === Email (SMTP) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@portlog.example.com

# === WhatsApp ===
WHATSAPP_MODE=local
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# === Logging ===
LOG_LEVEL=info
