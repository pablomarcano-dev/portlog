{
  "name": "portlog",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n schemas,backend,frontend -c cyan,blue,green \"npm run dev -w @portlog/schemas\" \"npm run start:dev -w @portlog/backend\" \"npm run dev -w @portlog/frontend\"",
    "build": "npm run build -w @portlog/schemas && npm run build -w @portlog/backend && npm run build -w @portlog/frontend",
    "lint": "eslint . --ext .ts,.tsx --ignore-path .gitignore",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/throttler": "^6.5.0"
  }
}
